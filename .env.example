# ============================================
# GRAND LINE — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (payments for fan art marketplace)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=https://grandline.gg
NEXT_PUBLIC_APP_NAME="Grand Line"

# Cloudinary (fan art uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Resend (transactional emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@grandline.gg

# Affiliate / Merch Partners
NEXT_PUBLIC_CRUNCHYROLL_AFFILIATE_ID=your-cr-affiliate-id
NEXT_PUBLIC_AMIAMI_AFFILIATE_ID=your-amiami-id

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ──────────────────────────────────────────────
# AI Engine (both are free tier, no credit card)
# ──────────────────────────────────────────────

# Groq — Primary AI provider (Llama 3.1 8B, sub-200ms, 500K tokens/day free)
# Sign up at: https://console.groq.com  →  API Keys  →  Create
GROQ_API_KEY=gsk_...

# Google Gemini Flash — Fallback AI (1M tokens/day free)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ──────────────────────────────────────────────
# Cron & Admin Jobs
# ──────────────────────────────────────────────

# Random secret used to authenticate cron endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
